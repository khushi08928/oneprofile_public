{
    "rewrites": [
        {
            "source": "/api/og-image/:username",
            "destination": "https://oneprofilebackend.madebykhushi.dev/api/v1/og/image/:username"
        },
        {
            "source": "/login",
            "destination": "/index.html"
        },
        {
            "source": "/signup",
            "destination": "/index.html"
        },
        {
            "source": "/onboarding",
            "destination": "/index.html"
        },
        {
            "source": "/profiles",
            "destination": "/index.html"
        },
        {
            "source": "/dashboard",
            "destination": "/index.html"
        },
        {
            "source": "/dashboard/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/og-home.png",
            "destination": "/og-home.png"
        },
        {
            "source": "/favicon-16x16.png",
            "destination": "/favicon-16x16.png"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },

        {
            "source": "/:username",
            "destination": "/api/[username]"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}